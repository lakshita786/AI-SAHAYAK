<!DOCTYPE html>
<html lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>AI Sahayak | About</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800;900&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script>
  tailwind.config = {
    darkMode: "class",
    theme: {
      extend: {
        colors: {
          "primary": "#a03b00",
          "primary-dark": "#c94c00",
          "surface": "#f9f9f9",
          "surface-container": "#f3f3f3",
          "on-surface": "#1a1c1c",
          "on-surface-variant": "#594138",
          "secondary": "#5f5e5e",
          "background": "#f9f9f9",
          "inverse-surface": "#2f3131"
        },
        fontFamily: { "headline": ["Public Sans"], "body": ["Public Sans"], "label": ["Public Sans"] },
        borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "2xl": "1rem", "full": "9999px"},
      },
    },
  }
</script>
<script>
// Mobile Bottom Navigation
document.write(`
<div class="mobile-nav">
  <a href="/" class="mobile-nav-item">
    <span class="material-symbols-outlined">home</span>
    Home
  </a>
  <a href="/eligibility" class="mobile-nav-item">
    <span class="material-symbols-outlined">verified</span>
    Eligibility
  </a>
  <a href="/schemes" class="mobile-nav-item">
    <span class="material-symbols-outlined">folder_special</span>
    Schemes
  </a>
  <a href="/support" class="mobile-nav-item">
    <span class="material-symbols-outlined">support_agent</span>
    Support
  </a>
  <a href="/about" class="mobile-nav-item active">
    <span class="material-symbols-outlined">info</span>
    About
  </a>
</div>
`);
</script>
<style>
  .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
  
  body { 
    font-family: 'Public Sans', sans-serif; 
    background: 
      radial-gradient(ellipse at 20% 20%, rgba(255, 248, 240, 0.8) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 80%, rgba(255, 236, 210, 0.6) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 50%, rgba(255, 245, 230, 0.4) 0%, transparent 70%),
      linear-gradient(180deg, #FFF9F5 0%, #FFF5EE 50%, #FFEEE0 100%);
    background-attachment: fixed;
    min-height: 100vh;
  }
  
  @keyframes float { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-8px); } }
  
  .glass-card {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.5);
    box-shadow: 0 8px 32px rgba(160, 59, 0, 0.08), 0 2px 8px rgba(160, 59, 0, 0.04), inset 0 1px 0 rgba(255, 255, 255, 0.6);
  }
  
  .floating-shadow { box-shadow: 0 20px 60px rgba(160, 59, 0, 0.12), 0 8px 20px rgba(160, 59, 0, 0.08); }
  
  .glass-header {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(255, 251, 245, 0.85) 50%, rgba(255, 245, 240, 0.9) 100%);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 229, 210, 0.5);
    box-shadow: 0 4px 30px rgba(160, 59, 0, 0.06);
  }
  
  .glass-footer {
    background: linear-gradient(180deg, rgba(255, 245, 230, 0.8) 0%, rgba(255, 255, 255, 0.9) 100%);
    backdrop-filter: blur(20px);
    border-top: 1px solid rgba(255, 229, 210, 0.4);
  }
  
  .hover-lift { transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
  .hover-lift:hover { transform: translateY(-4px); box-shadow: 0 15px 35px rgba(160, 59, 0, 0.15); }
  
  .gradient-text { background: linear-gradient(135deg, #a03b00, #c94c00, #e56a00); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  
  .btn-primary { background: linear-gradient(135deg, #a03b00 0%, #c94c00 50%, #e56a00 100%); transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(160, 59, 0, 0.3); }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 25px -5px rgba(160, 59, 0, 0.5); }
  
  @keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  .animate-fade { animation: fadeIn 0.4s ease-out; }
  .animate-card { animation: fadeInUp 0.5s ease-out; animation-fill-mode: both; }
  
  .tech-card { transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1); background: rgba(255, 255, 255, 0.6); }
  .tech-card:hover { transform: translateY(-4px); box-shadow: 0 15px 35px rgba(160, 59, 0, 0.15); background: rgba(255, 255, 255, 0.9); }
  
  @media (max-width: 768px) {
    .mobile-nav { display: flex; position: fixed; bottom: 0; left: 0; right: 0; background: linear-gradient(135deg, rgba(255,255,255,0.95), rgba(255,251,245,0.9)); backdrop-filter: blur(20px); border-top: 1px solid rgba(255,229,210,0.5); padding: 0.5rem; z-index: 100; }
    .mobile-nav-item { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 0.5rem; border-radius: 1rem; color: #5f5e5e; font-size: 0.7rem; font-weight: 500; text-decoration: none; }
    .mobile-nav-item.active { color: #a03b00; }
    .mobile-nav-item span:first-child { font-size: 1.5rem; margin-bottom: 0.25rem; }
    main { padding-bottom: 5rem !important; }
  }
</style>
</head>
<body class="flex flex-col min-h-screen text-on-surface">
<header class="fixed top-0 left-0 right-0 z-50 glass-header">
<div class="max-w-6xl mx-auto px-6 py-3.5 flex justify-between items-center">
<div class="flex items-center gap-3">
<div class="w-9 h-9 rounded-xl bg-gradient-to-br from-[#a03b00] to-[#c94c00] flex items-center justify-center shadow-md">
<span class="material-symbols-outlined text-white text-lg">psychology</span>
</div>
<div>
<span class="text-xl font-bold gradient-text">AI Sahayak</span>
<span class="text-[10px] text-[#5f5e5e] block -mt-0.5">एआई सहायक</span>
</div>
</div>
<nav class="hidden lg:flex items-center gap-1">
<a class="px-4 py-2 text-[#5f5e5e] font-medium hover:text-[#a03b00] hover:bg-[#fff5f0] rounded-lg transition-all hover-lift" href="/">Home</a>
<a class="px-4 py-2 text-[#5f5e5e] font-medium hover:text-[#a03b00] hover:bg-[#fff5f0] rounded-lg transition-all hover-lift" href="/eligibility">Eligibility</a>
<a class="px-4 py-2 text-[#5f5e5e] font-medium hover:text-[#a03b00] hover:bg-[#fff5f0] rounded-lg transition-all hover-lift" href="/schemes">Schemes</a>
<a class="px-4 py-2 text-[#5f5e5e] font-medium hover:text-[#a03b00] hover:bg-[#fff5f0] rounded-lg transition-all hover-lift" href="/support">Support</a>
<a class="px-4 py-2 text-[#a03b00] font-semibold bg-[#fff5f0] rounded-lg" href="/about">About</a>
</nav>
<div class="flex items-center gap-2">
<button class="p-2.5 text-[#5f5e5e] hover:text-[#a03b00] hover:bg-[#fff5f0] rounded-lg transition-all">
<span class="material-symbols-outlined text-xl">language</span>
</button>
<button class="p-2.5 text-[#5f5e5e] hover:text-[#a03b00] hover:bg-[#fff5f0] rounded-lg transition-all">
<span class="material-symbols-outlined text-xl">account_circle</span>
</button>
</div>
</div>
</header>

<main class="flex-grow pt-20 pb-16 px-4">
<div class="max-w-6xl mx-auto space-y-10">

<div class="text-center py-8 animate-fade">
  <div class="inline-flex items-center gap-2 bg-[#a03b00]/10 px-4 py-2 rounded-full mb-4">
    <span class="material-symbols-outlined text-[#a03b00]">psychology</span>
    <span class="text-sm font-semibold text-[#a03b00]">AI Powered Assistant</span>
  </div>
  <h1 class="text-4xl md:text-5xl font-bold text-[#1a1c1c] mb-3">
    About <span class="gradient-text">AI Sahayak</span>
  </h1>
  <p class="text-[#5f5e5e] text-lg max-w-2xl mx-auto">An AI-powered assistant helping rural workers in India discover government schemes in their own language.</p>
</div>

<div class="glass-card rounded-3xl p-10 text-center animate-card floating-shadow">
<h2 class="text-3xl font-bold mb-4 text-[#1a1c1c]">Try AI Sahayak Now</h2>
<p class="text-[#5f5e5e] text-lg mb-8 max-w-xl mx-auto">Check which government schemes you are eligible for in under 60 seconds.</p>
<div class="flex flex-col sm:flex-row gap-4 justify-center">
<a href="/eligibility" class="btn-primary bg-white text-[#a03b00] font-bold py-4 px-8 rounded-2xl hover:scale-105 transition-all shadow-xl">Check Eligibility</a>
<a href="/schemes" class="glass-card border-2 border-[#a03b00] text-[#a03b00] font-bold py-4 px-8 rounded-2xl hover:bg-[#fff5f0] transition-all">Browse Schemes</a>
</div>
</div>

<div class="animate-card" style="animation-delay: 0.1s">
<h3 class="text-xl font-bold text-[#1a1c1c] mb-6 flex items-center gap-3">
<span class="w-10 h-10 bg-[#a03b00]/10 rounded-xl flex items-center justify-center">
<span class="material-symbols-outlined text-[#a03b00] text-xl">settings_suggest</span>
</span>
How It Works
</h3>
<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
<div class="glass-card hover-lift rounded-2xl p-8 text-center">
<div class="w-16 h-16 bg-gradient-to-br from-[#a03b00] to-[#c94c00] rounded-2xl text-white font-bold text-2xl flex items-center justify-center mx-auto mb-5 shadow-lg">1</div>
<div class="w-14 h-14 bg-orange-100 rounded-2xl flex items-center justify-center mx-auto mb-5">
<span class="material-symbols-outlined text-orange-600 text-3xl">record_voice_over</span>
</div>
<h3 class="font-bold text-[#1a1c1c] text-lg mb-2">You Ask</h3>
<p class="text-[#5f5e5e]">Type or speak your question in Hindi or English</p>
</div>
<div class="glass-card hover-lift rounded-2xl p-8 text-center">
<div class="w-16 h-16 bg-gradient-to-br from-[#a03b00] to-[#c94c00] rounded-2xl text-white font-bold text-2xl flex items-center justify-center mx-auto mb-5 shadow-lg">2</div>
<div class="w-14 h-14 bg-blue-100 rounded-2xl flex items-center justify-center mx-auto mb-5">
<span class="material-symbols-outlined text-blue-600 text-3xl">psychology</span>
</div>
<h3 class="font-bold text-[#1a1c1c] text-lg mb-2">AI Understands</h3>
<p class="text-[#5f5e5e]">Our NLP classifier detects your intent and fetches relevant schemes</p>
</div>
<div class="glass-card hover-lift rounded-2xl p-8 text-center">
<div class="w-16 h-16 bg-gradient-to-br from-[#a03b00] to-[#c94c00] rounded-2xl text-white font-bold text-2xl flex items-center justify-center mx-auto mb-5 shadow-lg">3</div>
<div class="w-14 h-14 bg-green-100 rounded-2xl flex items-center justify-center mx-auto mb-5">
<span class="material-symbols-outlined text-green-600 text-3xl">verified</span>
</div>
<h3 class="font-bold text-[#1a1c1c] text-lg mb-2">You Get Help</h3>
<p class="text-[#5f5e5e] text-sm">Receive personalized scheme recommendations with eligibility check</p>
</div>
</div>
</div>

<div class="animate-card" style="animation-delay: 0.2s">
<h3 class="text-lg font-semibold text-[#1a1c1c] mb-4 flex items-center gap-2">
<span class="w-8 h-8 bg-[#a03b00]/10 rounded-lg flex items-center justify-center">
<span class="material-symbols-outlined text-[#a03b00] text-lg">code</span>
</span>
Built With
</h3>
<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
<div class="tech-card glass-card hover-lift rounded-xl p-5">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-[#a03b00] text-2xl">hub</span>
<div>
<p class="font-bold text-[#1a1c1c] text-sm">Groq + LLaMA 3.1</p>
<p class="text-[#5f5e5e] text-xs">Free AI model</p>
</div>
</div>
</div>
<div class="tech-card glass-card hover-lift rounded-xl p-5">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-[#a03b00] text-2xl">psychology</span>
<div>
<p class="font-bold text-[#1a1c1c] text-sm">Hugging Face</p>
<p class="text-[#5f5e5e] text-xs">NLP classification</p>
</div>
</div>
</div>
<div class="tech-card glass-card hover-lift rounded-xl p-5">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-[#a03b00] text-2xl">auto_awesome</span>
<div>
<p class="font-bold text-[#1a1c1c] text-sm">PyCaret AutoML</p>
<p class="text-[#5f5e5e] text-xs">Eligibility prediction</p>
</div>
</div>
</div>
<div class="tech-card glass-card hover-lift rounded-xl p-5">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-[#a03b00] text-2xl">code</span>
<div>
<p class="font-bold text-[#1a1c1c] text-sm">FastAPI</p>
<p class="text-[#5f5e5e] text-xs">Python backend</p>
</div>
</div>
</div>
<div class="tech-card glass-card hover-lift rounded-xl p-5">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-[#a03b00] text-2xl">brush</span>
<div>
<p class="font-bold text-[#1a1c1c] text-sm">Tailwind CSS</p>
<p class="text-[#5f5e5e] text-xs">Responsive styling</p>
</div>
</div>
</div>
<div class="tech-card glass-card hover-lift rounded-xl p-5">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-[#a03b00] text-2xl">storage</span>
<div>
<p class="font-bold text-[#1a1c1c] text-sm">Pandas + Sklearn</p>
<p class="text-[#5f5e5e] text-xs">Data processing</p>
</div>
</div>
</div>
<div class="tech-card glass-card hover-lift rounded-xl p-5">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-[#a03b00] text-2xl">terminal</span>
<div>
<p class="font-bold text-[#1a1c1c] text-sm">Kilo Code</p>
<p class="text-[#5f5e5e] text-xs">AI development</p>
</div>
</div>
</div>
<div class="tech-card glass-card hover-lift rounded-xl p-5">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-[#a03b00] text-2xl">cloud</span>
<div>
<p class="font-bold text-[#1a1c1c] text-sm">GitHub</p>
<p class="text-[#5f5e5e] text-xs">Version control</p>
</div>
</div>
</div>
</div>
</div>

<div class="bg-[#f8f8f8] rounded-2xl p-6 border border-gray-100 animate-card" style="animation-delay: 0.3s">
<div class="flex items-center gap-3 mb-4">
<div class="w-10 h-10 bg-[#a03b00]/10 rounded-xl flex items-center justify-center">
<span class="material-symbols-outlined text-[#a03b00] text-xl">school</span>
</div>
<h4 class="font-semibold text-[#1a1c1c] text-lg">Course Details</h4>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
<div class="flex gap-3"><span class="text-[#5f5e5e] text-sm">Course:</span><span class="font-semibold text-[#1a1c1c] text-sm">CAP-774 — AI Tools</span></div>
<div class="flex gap-3"><span class="text-[#5f5e5e] text-sm">University:</span><span class="font-semibold text-[#1a1c1c] text-sm">Chandigarh University</span></div>
<div class="flex gap-3"><span class="text-[#5f5e5e] text-sm">Problem:</span><span class="font-semibold text-[#1a1c1c] text-sm">Livelihood Support for Rural India</span></div>
<div class="flex gap-3"><span class="text-[#5f5e5e] text-sm">Tools:</span><span class="font-semibold text-[#1a1c1c] text-sm">AutoML · Groq API · Hugging Face NLP</span></div>
</div>
</div>

</div>
</main>

<footer class="glass-footer mt-auto">
<div class="max-w-6xl mx-auto px-6 py-8">
<div class="flex flex-col md:flex-row justify-between items-center gap-6">
<div class="flex items-center gap-3">
<div class="w-9 h-9 rounded-xl bg-gradient-to-br from-[#a03b00] to-[#c94c00] flex items-center justify-center">
<span class="material-symbols-outlined text-white text-lg">psychology</span>
</div>
<div>
<span class="text-base font-bold gradient-text">AI Sahayak</span>
<p class="text-xs text-[#5f5e5e] mt-0.5">Empowering Rural Livelihoods</p>
</div>
</div>
<nav class="flex items-center gap-8">
<a class="text-sm text-[#5f5e5e] hover:text-[#a03b00] transition-colors font-medium" href="/support">Privacy</a>
<a class="text-sm text-[#5f5e5e] hover:text-[#a03b00] transition-colors font-medium" href="/support">Terms</a>
<a class="text-sm text-[#5f5e5e] hover:text-[#a03b00] transition-colors font-medium" href="/support">Support</a>
</nav>
</div>
<div class="mt-6 pt-6 border-t border-gray-100 text-center">
<p class="text-xs text-[#a3a3a3]">© 2024 AI Sahayak. Built to help rural workers access government benefits.</p>
</div>
</div>
</footer>
</body></html>